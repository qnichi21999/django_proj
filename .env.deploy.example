# Скопируй в .env.deploy и заполни. Файл .env.deploy в git не попадает.

# Адрес и доступ к VPS
VPS_HOST=203.0.113.10
VPS_USER=root
VPS_PORT=22

# Куда класть проект на сервере
DEPLOY_DIR=/opt/mock-django

# Домен/хосты для Django (через запятую). Для теста по IP можно оставить *.
DJANGO_ALLOWED_HOSTS=*

# Секретный ключ для продакшена (сгенерируй случайный)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
